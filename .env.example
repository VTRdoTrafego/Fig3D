# Copie para .env e preencha. Variaveis VITE_* sao embutidas no build (npm run build).

# Obrigatorio para dados reais no Supabase (Project Settings > API)
VITE_SUPABASE_URL=https://SEU_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anon_publica

# false = login Supabase + tabelas/storage remotos | true = modo demo (localStorage + uploads locais)
VITE_PUBLIC_MODE=false

# Opcional: JSON de branding remoto (HTTPS). Senao usa public/branding.public.json ou src/data/publicBranding.default.json
# VITE_PUBLIC_BRANDING_URL=

# Opcional: checkout (PricingCards)
# VITE_CHECKOUT_MONTHLY_URL=
# VITE_CHECKOUT_ANNUAL_URL=
